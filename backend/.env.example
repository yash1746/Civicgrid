# ──────────────────────────────────────────────
# CivicGrid Backend — Environment Variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_NAME=CivicGrid
APP_ENV=development
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Supabase ─────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Google Gemini AI ─────────────────────────
GEMINI_API_KEY=your-google-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro

# ── Supabase Storage Bucket Names ────────────
ISSUE_MEDIA_BUCKET=issue-media
PROOF_MEDIA_BUCKET=proof-media

# ── Email (SendGrid) ─────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM=noreply@civicgrid.io
EMAIL_FROM_NAME=CivicGrid Alerts

# ── Twitter/X API ────────────────────────────
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# ── Instagram Graph API ───────────────────────
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
INSTAGRAM_ACCOUNT_ID=your-instagram-account-id

# ── SLA Config (hours) ───────────────────────
SLA_HOURS_LOW=72
SLA_HOURS_MEDIUM=48
SLA_HOURS_HIGH=24
SLA_HOURS_CRITICAL=4

# ── CORS ─────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","https://civicgrid.io"]
